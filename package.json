{
    "name": "shintea",
    "private": true,
    "version": "1.0.0",
    "description": "Profesyonel Şantiye Depo Yönetim Sistemi",
    "author": "Antigravity",
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "electron:start": "NODE_ENV=development electron .",
        "electron:build": "npm run build && electron-builder"
    },
    "build": {
        "appId": "com.shintea.app",
        "productName": "Shintea",
        "directories": {
            "output": "dist_electron"
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "package.json"
        ],
        "mac": {
            "category": "public.app-category.business",
            "target": [
                "dmg"
            ]
        }
    },
    "dependencies": {
        "firebase": "^12.11.0",
        "jspdf": "^4.2.0",
        "jspdf-autotable": "^5.0.7",
        "lucide-react": "^0.454.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.1",
        "electron": "^40.4.1",
        "electron-builder": "^26.7.0",
        "eslint": "^9.13.0",
        "eslint-plugin-react": "^7.37.1",
        "eslint-plugin-react-hooks": "^5.0.0",
        "eslint-plugin-react-refresh": "^0.4.14",
        "firebase-tools": "^15.12.0",
        "vite": "8.0.3"
    }
}
